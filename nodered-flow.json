	{
		"id": "b86d36ccba2da8db",
		"type": "function",
		"z": "589563619b7481ee",
		"name": "Calc new current (solar only)",
		"func": "const p1 = Number(msg.p1_power);\nlet current = Number(msg.current_setpoint);\nconst wattsPerAmp = 400;\nconst marginW = wattsPerAmp;\nconst minA = 0;\nconst maxA = 32;\nif (isNaN(p1) || isNaN(current)) return null;\nif (p1 > marginW) current -= 1;\nelse if (p1 < -marginW) current += 1;\nif (current < minA) current = minA;\nif (current > maxA) current = maxA;\nmsg.new_current = Math.round(current);\nreturn msg;",
