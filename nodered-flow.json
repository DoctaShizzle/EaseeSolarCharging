	{
		"id": "033c887714f00b43",
		"type": "function",
		"z": "589563619b7481ee",
		"name": "Calc new current (surplus)",
		"func": "const p1 = Number(msg.p1_power);\nlet current = Number(msg.current_setpoint);\nconst wattsPerAmp = 400;\nconst marginW = wattsPerAmp;\nconst minA = 6;\nconst maxA = 32;\nif (isNaN(p1) || isNaN(current)) return null;\nif (p1 > marginW) current -= 1;\nelse if (p1 < -marginW) current += 1;\nif (current < minA) current = minA;\nif (current > maxA) current = maxA;\nmsg.new_current = Math.round(current);\nreturn msg;",
		"outputs": 1,
		"x": 1880,
		"y": 820,
		"wires": [
			[
				"baea14a161d35e1b",
				"1d2e601bb8f5b12a"
			]
		]
